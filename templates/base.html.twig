
<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>{% block title %}Блог{% endblock %}</title>

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
<header>
    <nav>
        <a href="{{ path('app_home') }}">Блог</a>
        <a href="{{ path('app_about') }}">О блоге</a>
        {% if app.user %}
            <a href="{{ path('app_publication_create') }}">Создать публикацию</a>
            <span>{{ app.user.userIdentifier }}</span>
            <a href="{{ path('app_logout') }}">Выйти</a>
        {% else %}
            <a href="{{ path('app_login') }}">Войти</a>
        {% endif %}
    </nav>
</header>

<main>
    {% block body %}{% endblock %}

</main>

<footer>
    <p>&copy; {{ 'now'|date('Y') }} Блог</p>
</footer>
</body>
</html>
