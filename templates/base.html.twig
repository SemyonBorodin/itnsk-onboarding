<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Блог{% endblock %}</title>
    <meta name="description" content="{% block description %}Блог{% endblock %}">
    <link rel="icon" href="{{ asset('silicon/img/logo.svg') }}" type="image/svg+xml">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('silicon/css/theme.css') }}">
    {% endblock %}
</head>
<body>
<header class="navbar">
    <div class="container navbar-inner">
        <a class="navbar-brand" href="{{ path('app_home') }}">
            <img src="{{ asset('silicon/img/logo.svg') }}" alt="">
            Блог
        </a>

        <nav class="navbar-nav" aria-label="Основная навигация">
            <a href="{{ path('app_home') }}">Публикации</a>
            <a href="{{ path('app_about') }}">О блоге</a>
            {% if app.user %}
                <a class="btn btn-primary" href="{{ path('app_publication_create') }}">
                    Создать публикацию
                </a>
                <span class="navbar-user">{{ app.user.userIdentifier }}</span>
                <a href="{{ path('app_logout') }}">Выйти</a>
            {% else %}
                <a class="btn btn-outline" href="{{ path('app_login') }}">Войти</a>
            {% endif %}
        </nav>
    </div>
</header>

<main class="page-wrapper">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type }}" role="alert">
                {{ message }}
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

<footer class="footer">
    <div class="container footer-inner">
        <strong>Блог</strong>
        <span>&copy; <span data-current-year>{{ 'now'|date('Y') }}</span></span>
    </div>
</footer>

{% block javascripts %}
    <script src="{{ asset('silicon/js/theme.js') }}"></script>
{% endblock %}
</body>
</html>
